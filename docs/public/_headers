# Hashed VitePress build assets — filename hash invalidates on rebuild,
# so we can cache for a year with `immutable`.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Generated OG images — only change when slug/title changes.
/og/*
  Cache-Control: public, max-age=2592000

# Tutorial videos + posters
/volume_fix/*
  Cache-Control: public, max-age=2592000

# Per-product / per-app folders
/app_icon/*
  Cache-Control: public, max-age=2592000

/qc-lc/*
  Cache-Control: public, max-age=2592000

# Root-level static media (logos, box photos, etc.)
/*.webp
  Cache-Control: public, max-age=2592000

/*.png
  Cache-Control: public, max-age=2592000

/*.jpg
  Cache-Control: public, max-age=2592000

/*.webm
  Cache-Control: public, max-age=2592000

/*.ico
  Cache-Control: public, max-age=2592000

# Manifest can shift occasionally — short cache.
/site.webmanifest
  Cache-Control: public, max-age=86400

# Service worker must always be fresh so updates roll out.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /
