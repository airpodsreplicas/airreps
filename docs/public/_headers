# HTML pages - cache on CDN for 1 day, browsers always revalidate
/*.html
  Cache-Control: public, max-age=0, s-maxage=86400

/
  Cache-Control: public, max-age=0, s-maxage=86400

# Hashed assets (VitePress adds content hashes) - cache aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable
